meta {
  name: Add Member
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/projects/{{projectId}}/members
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "email": "john@example.com"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("memberUserId", res.body.userId);
  }
}
