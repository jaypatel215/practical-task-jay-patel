meta {
  name: Create Task
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/projects/{{projectId}}/tasks
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "Design homepage mockup",
    "description": "Create wireframes for the new homepage",
    "status": "BACKLOG",
    "priority": "HIGH",
    "dueDate": "2026-07-15"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("taskId", res.body.id);
  }
}
