meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "jay@yopmail.com",
    "password": "password123",
    "name": "Jay Patel"
  }
}

vars:pre-request {
  baseUrl: http://localhost:4000/api
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("token", res.body.token);
  }
}
